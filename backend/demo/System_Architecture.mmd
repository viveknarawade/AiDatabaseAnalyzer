graph TB
    subgraph ClientLayer["Client Layer"]
        WEB["React + Vite SPA"]
        MOB["Mobile Web PWA"]
    end

    subgraph EdgeLayer["Edge / Gateway Layer"]
        CDN["CDN - Static Assets"]
        LB["Load Balancer - Nginx"]
        GW["API Gateway - Rate Limiting - Auth Check - Routing"]
    end

    subgraph AppLayer["Application Layer - Spring Boot"]
        direction TB
        AUTH["Auth Module - JWT + RBAC"]
        PROJ["Project Module"]
        CONN["Connector Module - DB Connections"]
        SCHEMA["Schema Module - Extraction + Parsing"]
        DQ["Data Quality Module"]
        NLQ["NL to SQL Module"]
        INSIGHT["Insight Module"]
        SUMMARY["AI Summary Module"]
        DICT["Data Dictionary Module"]
        JOBS["Job Orchestrator"]
    end

    subgraph DataLayer["Data Layer"]
        MYSQL[("MySQL Primary - App Data")]
        REPLICA[("MySQL Read Replica")]
        REDIS[("Redis - Cache + Queue")]
    end

    subgraph ExternalLayer["External Services"]
        LLM["OpenAI API - GPT-4"]
        EXTDB1[("Customer DB 1 - PostgreSQL")]
        EXTDB2[("Customer DB 2 - MySQL")]
        EXTDB3[("Customer DB 3 - SQL Server")]
        SMTP["Email Service - SMTP"]
    end

    subgraph AsyncLayer["Async Processing"]
        WORKER1["Worker 1 - Schema Jobs"]
        WORKER2["Worker 2 - Quality Jobs"]
        WORKER3["Worker 3 - AI Jobs"]
    end

    WEB --> CDN
    MOB --> CDN
    CDN --> LB
    LB --> GW
    GW --> AUTH
    GW --> PROJ
    GW --> CONN
    GW --> SCHEMA
    GW --> DQ
    GW --> NLQ
    GW --> INSIGHT
    GW --> SUMMARY
    GW --> DICT

    AUTH --> MYSQL
    PROJ --> MYSQL
    CONN --> MYSQL
    SCHEMA --> MYSQL
    DQ --> MYSQL
    NLQ --> MYSQL
    INSIGHT --> MYSQL
    SUMMARY --> MYSQL
    DICT --> MYSQL

    SCHEMA --> REDIS
    DQ --> REDIS
    NLQ --> REDIS
    INSIGHT --> REDIS
    SUMMARY --> REDIS
    JOBS --> REDIS

    CONN --> EXTDB1
    CONN --> EXTDB2
    CONN --> EXTDB3

    NLQ --> LLM
    INSIGHT --> LLM
    SUMMARY --> LLM

    REDIS --> WORKER1
    REDIS --> WORKER2
    REDIS --> WORKER3

    WORKER1 --> MYSQL
    WORKER2 --> MYSQL
    WORKER3 --> MYSQL
    WORKER3 --> LLM

    AUTH --> SMTP

    MYSQL --> REPLICA
    SCHEMA -.->|reads| REPLICA
    DQ -.->|reads| REPLICA
